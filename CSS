/* ------------------------------
   BRENDAFLIX - LOGIN CUSTOM
------------------------------ */

/* Logo imagem (substitui o texto) */
.pageTitle{
  font-size: 0;
  text-align: center;
  height: 80px;
  background-image: url("https://raw.githubusercontent.com/3rian/Mida-Center/refs/heads/main/logo.png"); /* use nome sem acentos */
  background-repeat: no-repeat;
  background-position: center center;
  background-size: contain;
  margin: 0 auto 20px auto;
  max-width: 300px;
  width: 100%;
}
.pageTitle::after {
  content: none;
}

/* Fundo com a arte */
#loginPage,
#loginPage .backgroundContainer{
  background:
    linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), /* escurece um pouco para destacar o formulário */
    url("/web/backgrounds/BrendaFlix.png") center center / cover no-repeat fixed;
}

/* Container do formulário – reposicionado mais abaixo */
#loginPage .readOnlyContent,
#loginPage form{
  max-width: 22em;
  margin-top: 280px;              /* AUMENTE ou DIMINUA este valor conforme necessário */
  margin-bottom: 40px;
  background: rgba(0,0,0,0.75);
  padding: 30px;
  border-radius: 14px;
  backdrop-filter: blur(10px);
  box-shadow: 0 15px 40px rgba(0,0,0,0.7);
  border: 1px solid rgba(255,255,255,0.1);
}

/* Esconder textos padrão e botões indesejados */
#loginPage h1,
#loginPage .btnManual,
#loginPage .btnForgotPassword{
  display:none;
}

/* Campos de entrada */
#loginPage input{
  background: rgba(20,20,20,0.9);
  border: 1px solid rgba(255,255,255,0.15);
  color: white;
  border-radius: 8px;
  padding: 14px;                  /* um pouco maior para melhor toque */
  font-size: 16px;
  transition: 0.2s;
}

#loginPage input::placeholder{
  color: rgba(255,255,255,0.5);
  font-weight: 400;
}

#loginPage input:focus{
  border-color: #e50914;
  box-shadow: 0 0 12px rgba(229,9,20,0.6);
  outline: none;
  background: rgba(30,30,30,0.9);
}

/* Labels */
#loginPage label{
  color: rgba(255,255,255,0.9);
  font-weight: 500;
  margin-bottom: 6px;
  display: block;
}

/* Botão de login – ESTILIZAÇÃO REFINADA */
#loginPage .btnLogin{
  background: linear-gradient(145deg, #e50914, #b00610); /* gradiente sutil */
  border: none;
  border-radius: 10px;
  font-weight: 700;
  font-size: 18px;
  letter-spacing: 1.2px;
  padding: 14px 20px;
  color: white;
  text-transform: uppercase;
  box-shadow: 0 8px 20px rgba(229,9,20,0.4);
  transition: all 0.25s ease;
  cursor: pointer;
  width: 100%;
  margin-top: 10px;
}

#loginPage .btnLogin:hover{
  background: linear-gradient(145deg, #ff1f2f, #c00914);
  transform: translateY(-2px) scale(1.02); /* leve elevação e aumento */
  box-shadow: 0 12px 28px rgba(229,9,20,0.6);
}

#loginPage .btnLogin:active{
  transform: translateY(1px) scale(0.98);
  box-shadow: 0 4px 12px rgba(229,9,20,0.5);
}

