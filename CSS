/* ------------------------------
   MOBILE FIX (vertical)
------------------------------ */
@media (max-width:600px){
  .pageTitle {
    height: 60px;
    max-width: 200px;
  }

  #loginPage .readOnlyContent,
  #loginPage form{
    margin-top: 180px;            /* menor que desktop, mas ainda afastado do topo */
    padding: 20px;
  }

  #loginPage .btnLogin {
    font-size: 16px;
    padding: 12px;
  }
}
